<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>We Hate Lightspeed</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Raleway:wght@300;400;600;700&display=swap" rel="stylesheet"/>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>

<style>
:root{
--bg:#050505;
--bg2:#0b0b0b;
--surface:rgba(255,255,255,0.04);
--surface2:rgba(255,255,255,0.06);
--border:rgba(255,255,255,0.12);
--border2:rgba(255,255,255,0.2);
--text:#ffffff;
--muted:rgba(255,255,255,0.7);
--muted2:rgba(255,255,255,0.45);
--accent:#ffffff;
--accent2:#d8d8d8;
--glow:0 0 30px rgba(255,255,255,0.12);
--glow2:0 0 60px rgba(255,255,255,0.06);
}

*{margin:0;padding:0;box-sizing:border-box;}
html,body{
width:100%;
height:100%;
overflow:hidden;
font-family:'Raleway',sans-serif;
background:var(--bg);
color:var(--text);
}

#bg-canvas{
position:fixed;
inset:0;
z-index:0;
pointer-events:none;
}

.blob{
position:fixed;
border-radius:50%;
pointer-events:none;
z-index:0;
filter:blur(60px);
mix-blend-mode:screen;
animation:blobPulse ease-in-out infinite alternate;
}
@keyframes blobPulse{
from{transform:scale(1) translate(0,0);}
to{transform:scale(1.12) translate(10px,-10px);}
}

.petal{
position:fixed;
top:-60px;
pointer-events:none;
z-index:1;
animation:petalFall linear infinite;
opacity:0;
}
.petal svg{
filter:drop-shadow(0 0 6px rgba(255,255,255,0.35));
}
@keyframes petalFall{
0%{transform:translateY(0) rotate(0deg) scale(1);opacity:0;}
5%{opacity:.85;}
90%{opacity:.55;}
100%{transform:translateY(110vh) rotate(720deg) scale(.6);opacity:0;}
}

.page{
position:fixed;
inset:0;
z-index:10;
display:flex;
align-items:center;
justify-content:center;
flex-direction:column;
transition:opacity .5s,transform .5s;
}
.page.hidden{
opacity:0;
pointer-events:none;
transform:scale(.97);
}

.glass{
background:rgba(10,10,10,.82);
border:1px solid var(--border);
border-radius:24px;
backdrop-filter:blur(24px);
box-shadow:0 8px 60px rgba(0,0,0,.7),var(--glow2);
padding:48px 56px;
width:min(500px,92vw);
position:relative;
overflow:hidden;
}
.glass::before{
content:'';
position:absolute;
inset:0;
background:radial-gradient(ellipse at 50% 0%,rgba(255,255,255,.08) 0%,transparent 70%);
pointer-events:none;
}

.site-title{
font-family:'Cinzel Decorative',cursive;
font-size:clamp(1.4rem,4vw,2.2rem);
font-weight:900;
text-align:center;
background:linear-gradient(135deg,#fff 0%,#dcdcdc 45%,#ffffff 100%);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
background-clip:text;
letter-spacing:2px;
margin-bottom:8px;
filter:drop-shadow(0 0 20px rgba(255,255,255,.2));
}
.site-sub{
text-align:center;
font-size:.75rem;
letter-spacing:4px;
color:rgba(255,255,255,.6);
text-transform:uppercase;
margin-bottom:36px;
}

label{
font-size:.7rem;
letter-spacing:3px;
text-transform:uppercase;
color:rgba(255,255,255,.65);
display:block;
margin-bottom:8px;
}

input[type=text],input[type=password]{
width:100%;
padding:14px 18px;
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.15);
border-radius:12px;
color:#fff;
font-family:'Raleway',sans-serif;
font-size:.95rem;
outline:none;
transition:border .3s,box-shadow .3s,background .3s;
margin-bottom:20px;
}
input::placeholder{
color:rgba(255,255,255,.35);
}
input:focus{
border-color:#fff;
box-shadow:0 0 20px rgba(255,255,255,.15);
background:rgba(255,255,255,.07);
}

.btn{
width:100%;
padding:16px;
border:none;
border-radius:14px;
cursor:pointer;
font-family:'Cinzel Decorative',cursive;
font-size:.85rem;
font-weight:700;
letter-spacing:2px;
text-transform:uppercase;
position:relative;
overflow:hidden;
transition:transform .2s,box-shadow .3s,background .3s,opacity .3s;
background:linear-gradient(135deg,#ffffff,#d7d7d7,#ffffff);
background-size:200% 200%;
animation:gradShift 4s ease infinite;
color:#000;
text-shadow:none;
box-shadow:0 4px 30px rgba(255,255,255,.12),inset 0 1px 0 rgba(255,255,255,.35);
}
.btn::after{
content:'';
position:absolute;
inset:0;
background:radial-gradient(ellipse at 50% 0%,rgba(255,255,255,.26) 0%,transparent 60%);
pointer-events:none;
}
.btn::before{
content:'';
position:absolute;
top:-10px;
left:50%;
transform:translateX(-50%);
width:30px;
height:20px;
background:rgba(255,255,255,.75);
border-radius:0 0 50% 50%;
filter:blur(4px);
animation:goopDrip 3s ease-in-out infinite;
}
@keyframes goopDrip{
0%,100%{height:20px;opacity:.65;top:-10px;}
50%{height:40px;opacity:.35;top:-5px;}
}
@keyframes gradShift{
0%,100%{background-position:0% 50%;}
50%{background-position:100% 50%;}
}
.btn:hover{
transform:translateY(-3px);
box-shadow:0 8px 40px rgba(255,255,255,.18),var(--glow);
}
.btn.secondary{
background:transparent;
border:1px solid rgba(255,255,255,.25);
color:var(--text);
font-size:.75rem;
padding:11px;
animation:none;
box-shadow:none;
}
.btn.secondary::before,
.btn.secondary::after{
display:none;
}
.btn.secondary:hover{
background:rgba(255,255,255,.07);
border-color:#fff;
}

.err-msg{
background:rgba(255,255,255,.06);
border:1px solid rgba(255,255,255,.18);
border-radius:10px;
padding:12px 16px;
font-size:.8rem;
color:#fff;
text-align:center;
margin-bottom:16px;
display:none;
animation:shake .4s ease;
}
@keyframes shake{
0%,100%{transform:translateX(0);}
25%{transform:translateX(-8px);}
75%{transform:translateX(8px);}
}

#banned-page .glass{
border-color:rgba(255,255,255,.3);
box-shadow:0 0 80px rgba(255,255,255,.12);
}
#banned-page h2{
font-family:'Cinzel Decorative',cursive;
color:#fff;
font-size:1.8rem;
text-align:center;
margin-bottom:16px;
animation:pulse 2s ease infinite;
}
@keyframes pulse{
0%,100%{opacity:1;}
50%{opacity:.5;}
}
#banned-page p{
text-align:center;
color:rgba(255,255,255,.72);
font-size:.9rem;
line-height:1.7;
}

.topbar{
position:fixed;
top:0;
left:0;
right:0;
z-index:100;
height:60px;
display:flex;
align-items:center;
padding:0 24px;
background:rgba(5,5,5,.9);
border-bottom:1px solid rgba(255,255,255,.1);
backdrop-filter:blur(20px);
gap:12px;
}
.topbar .logo{
font-family:'Cinzel Decorative',cursive;
font-size:.85rem;
background:linear-gradient(90deg,#fff,#d7d7d7);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
background-clip:text;
white-space:nowrap;
flex-shrink:0;
}
.topbar-spacer{flex:1;}
.user-badge{
display:flex;
align-items:center;
gap:8px;
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.12);
border-radius:20px;
padding:6px 14px;
font-size:.75rem;
color:#fff;
}
.dot{
width:7px;
height:7px;
border-radius:50%;
background:#fff;
animation:blink 2s infinite;
}
@keyframes blink{
0%,100%{opacity:1;}
50%{opacity:.2;}
}
.role-badge{
padding:3px 10px;
border-radius:20px;
font-size:.65rem;
letter-spacing:1px;
text-transform:uppercase;
font-weight:600;
}
.role-std{
background:rgba(255,255,255,.08);
color:#fff;
border:1px solid rgba(255,255,255,.22);
}
.role-sys{
background:rgba(255,255,255,.14);
color:#fff;
border:1px solid rgba(255,255,255,.34);
}

.tabs{
display:flex;
gap:4px;
padding:0 24px;
position:fixed;
top:60px;
left:0;
right:0;
z-index:99;
background:rgba(5,5,5,.88);
border-bottom:1px solid rgba(255,255,255,.08);
backdrop-filter:blur(12px);
overflow-x:auto;
scrollbar-width:none;
}
.tabs::-webkit-scrollbar{display:none;}
.tab-btn{
padding:12px 20px;
background:transparent;
border:none;
cursor:pointer;
font-family:'Raleway',sans-serif;
font-size:.78rem;
font-weight:600;
letter-spacing:1px;
text-transform:uppercase;
color:rgba(255,255,255,.45);
border-bottom:2px solid transparent;
transition:all .3s;
white-space:nowrap;
}
.tab-btn:hover{color:#fff;}
.tab-btn.active{
color:#fff;
border-bottom-color:#fff;
}

.content{
position:fixed;
top:104px;
left:0;
right:0;
bottom:0;
overflow-y:auto;
padding:28px 28px 40px;
scrollbar-width:thin;
scrollbar-color:rgba(255,255,255,.3) transparent;
}
.tab-panel{
display:none;
animation:fadeIn .4s ease;
}
.tab-panel.active{display:block;}
@keyframes fadeIn{
from{opacity:0;transform:translateY(8px);}
to{opacity:1;transform:none;}
}
.panel-title{
font-family:'Cinzel Decorative',cursive;
font-size:1.2rem;
background:linear-gradient(90deg,#fff,#d7d7d7);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
background-clip:text;
margin-bottom:20px;
}

.games-grid{
display:grid;
grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
gap:16px;
}
.game-card{
background:rgba(255,255,255,.04);
border:1px solid var(--border);
border-radius:16px;
padding:28px 20px;
text-align:center;
cursor:pointer;
transition:all .3s;
position:relative;
overflow:hidden;
}
.game-card::before{
content:'';
position:absolute;
inset:0;
background:radial-gradient(ellipse at 50% 100%,rgba(255,255,255,.08) 0%,transparent 70%);
pointer-events:none;
transition:opacity .3s;
opacity:0;
}
.game-card:hover{
transform:translateY(-6px);
border-color:rgba(255,255,255,.25);
box-shadow:0 10px 40px rgba(255,255,255,.08);
}
.game-card:hover::before{opacity:1;}
.game-icon{
font-size:2.5rem;
margin-bottom:12px;
display:block;
}
.game-card h3{
font-family:'Cinzel Decorative',cursive;
font-size:.85rem;
color:#fff;
margin-bottom:6px;
}
.game-card p{
font-size:.75rem;
color:rgba(255,255,255,.5);
}

/* EMBED GAME CARD in games grid */
.embed-game-card{
background:rgba(255,255,255,.04);
border:1px solid rgba(255,255,255,.22);
border-radius:16px;
padding:28px 20px;
text-align:center;
cursor:pointer;
transition:all .3s;
position:relative;
overflow:hidden;
grid-column:span 1;
}
.embed-game-card::before{
content:'';
position:absolute;
inset:0;
background:radial-gradient(ellipse at 50% 100%,rgba(255,255,255,.1) 0%,transparent 70%);
pointer-events:none;
opacity:0;
transition:opacity .3s;
}
.embed-game-card:hover{
transform:translateY(-6px);
border-color:rgba(255,255,255,.4);
box-shadow:0 10px 40px rgba(255,255,255,.1);
}
.embed-game-card:hover::before{opacity:1;}
.embed-game-card .embed-badge{
display:inline-block;
background:rgba(255,255,255,.12);
border:1px solid rgba(255,255,255,.28);
border-radius:8px;
font-size:.6rem;
letter-spacing:2px;
text-transform:uppercase;
color:rgba(255,255,255,.7);
padding:3px 9px;
margin-bottom:12px;
font-family:'Raleway',sans-serif;
}

.game-frame-wrap{display:none;}
.game-frame-wrap.active{display:block;}
.back-btn{
padding:8px 18px;
background:transparent;
border:1px solid rgba(255,255,255,.24);
border-radius:10px;
color:#fff;
cursor:pointer;
font-size:.78rem;
margin-bottom:16px;
transition:all .3s;
}
.back-btn:hover{
background:rgba(255,255,255,.07);
}

/* EMBED IFRAME VIEWER */
#embed-viewer{
display:none;
flex-direction:column;
height:calc(100vh - 148px);
}
#embed-viewer.active{
display:flex;
}
#embed-viewer-header{
display:flex;
align-items:center;
gap:12px;
margin-bottom:14px;
flex-wrap:wrap;
}
#embed-iframe{
flex:1;
width:100%;
border:1px solid rgba(255,255,255,.16);
border-radius:14px;
background:#090909;
}

/* FULLSCREEN OVERLAY */
#fullscreen-overlay{
position:fixed;
inset:0;
z-index:9996;
background:#000;
display:none;
flex-direction:column;
}
#fullscreen-overlay.active{
display:flex;
}
#fullscreen-overlay-bar{
display:flex;
align-items:center;
gap:12px;
padding:10px 16px;
background:rgba(0,0,0,.9);
border-bottom:1px solid rgba(255,255,255,.1);
flex-shrink:0;
}
#fullscreen-overlay-bar span{
font-family:'Cinzel Decorative',cursive;
font-size:.75rem;
color:rgba(255,255,255,.6);
flex:1;
}
#fullscreen-iframe{
flex:1;
width:100%;
border:none;
}
.fs-close-btn{
padding:7px 18px;
background:rgba(255,255,255,.1);
border:1px solid rgba(255,255,255,.25);
border-radius:9px;
color:#fff;
cursor:pointer;
font-size:.78rem;
transition:all .2s;
}
.fs-close-btn:hover{
background:rgba(255,255,255,.2);
}

.admin-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
}
@media(max-width:640px){
.admin-grid{grid-template-columns:1fr;}
}
.admin-full{grid-column:1/-1;}
.admin-card{
background:rgba(255,255,255,.03);
border:1px solid var(--border);
border-radius:18px;
padding:24px;
position:relative;
overflow:hidden;
}
.admin-card h3{
font-family:'Cinzel Decorative',cursive;
font-size:.8rem;
color:#fff;
margin-bottom:16px;
letter-spacing:1px;
}
.online-list,.ban-list{
list-style:none;
display:flex;
flex-direction:column;
gap:8px;
}
.online-list li,.ban-list li{
display:flex;
align-items:center;
justify-content:space-between;
padding:10px 14px;
background:rgba(255,255,255,.04);
border:1px solid rgba(255,255,255,.08);
border-radius:10px;
font-size:.82rem;
}
.online-list li .uname{
display:flex;
align-items:center;
gap:8px;
}
.ban-btn{
padding:5px 12px;
background:rgba(255,255,255,.08);
border:1px solid rgba(255,255,255,.25);
border-radius:8px;
color:#fff;
cursor:pointer;
font-size:.72rem;
transition:all .2s;
}
.ban-btn:hover{
background:rgba(255,255,255,.16);
}
.ban-info{
display:flex;
flex-direction:column;
gap:2px;
}
.ban-name{
font-weight:600;
color:#fff;
}
.ban-meta{
font-size:.7rem;
color:rgba(255,255,255,.35);
}

.stat-row{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:12px;
}
@media(max-width:500px){
.stat-row{grid-template-columns:1fr 1fr;}
}
.stat-chip{
background:rgba(255,255,255,.04);
border:1px solid rgba(255,255,255,.1);
border-radius:14px;
padding:18px 16px;
text-align:center;
}
.stat-val{
font-family:'Cinzel Decorative',cursive;
font-size:1.4rem;
color:#fff;
margin-bottom:4px;
}
.stat-lbl{
font-size:.65rem;
letter-spacing:2px;
text-transform:uppercase;
color:rgba(255,255,255,.45);
}

.admin-log{
max-height:180px;
overflow-y:auto;
scrollbar-width:thin;
scrollbar-color:rgba(255,255,255,.25) transparent;
}
.log-entry{
display:flex;
gap:10px;
align-items:flex-start;
padding:8px 0;
border-bottom:1px solid rgba(255,255,255,.04);
font-size:.76rem;
}
.log-entry:last-child{border-bottom:none;}
.log-time{
color:rgba(255,255,255,.38);
flex-shrink:0;
width:70px;
}
.log-text{
color:rgba(255,255,255,.7);
line-height:1.5;
}
.log-tag{
padding:2px 7px;
border-radius:6px;
font-size:.62rem;
font-weight:600;
flex-shrink:0;
letter-spacing:.5px;
}
.log-tag.join{background:rgba(255,255,255,.1);color:#fff;}
.log-tag.leave{background:rgba(255,255,255,.08);color:#ddd;}
.log-tag.ban{background:rgba(255,255,255,.12);color:#fff;}
.log-tag.msg{background:rgba(255,255,255,.1);color:#fff;}
.log-tag.lock{background:rgba(255,255,255,.14);color:#fff;}
.log-tag.embed{background:rgba(255,255,255,.1);color:#fff;}

.global-msg-row{
display:flex;
gap:10px;
align-items:flex-start;
}
.global-msg-row textarea{
flex:1;
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.2);
border-radius:12px;
padding:12px 16px;
color:#fff;
font-family:'Raleway',sans-serif;
font-size:.88rem;
outline:none;
resize:none;
height:80px;
transition:border .3s;
}
.global-msg-row textarea:focus{
border-color:#fff;
}
.msg-btn-col{
display:flex;
flex-direction:column;
gap:8px;
}

.lockdown-btn{
padding:14px 28px;
background:linear-gradient(135deg,#1f1f1f,#000);
border:1px solid rgba(255,255,255,.22);
border-radius:12px;
color:#fff;
cursor:pointer;
font-family:'Cinzel Decorative',cursive;
font-size:.78rem;
letter-spacing:1px;
transition:all .3s;
box-shadow:0 4px 20px rgba(255,255,255,.08);
}
.lockdown-btn:hover{
transform:translateY(-2px);
box-shadow:0 6px 30px rgba(255,255,255,.12);
}

.pw-vault{
display:flex;
flex-direction:column;
gap:10px;
}
.pw-section-label{
font-size:.63rem;
letter-spacing:3px;
text-transform:uppercase;
color:rgba(255,255,255,.3);
padding-top:6px;
}
.pw-row{
display:flex;
align-items:center;
justify-content:space-between;
padding:12px 16px;
background:rgba(255,255,255,.03);
border:1px solid rgba(255,255,255,.1);
border-radius:12px;
gap:12px;
flex-wrap:wrap;
}
.pw-label{
font-size:.72rem;
letter-spacing:1px;
text-transform:uppercase;
color:rgba(255,255,255,.6);
min-width:150px;
}
.pw-val{
font-family:monospace;
font-size:.9rem;
color:#fff;
background:rgba(255,255,255,.06);
padding:5px 12px;
border-radius:8px;
border:1px solid rgba(255,255,255,.08);
letter-spacing:1px;
flex:1;
text-align:center;
transition:all .3s;
cursor:pointer;
user-select:none;
/* visibility:hidden hides content from inspect-element too, unlike blur */
color:transparent;
text-shadow:0 0 8px rgba(255,255,255,0.8);
}
.pw-val.show{
color:#fff;
text-shadow:none;
user-select:text;
}
.pw-show-btn{
padding:5px 14px;
background:rgba(255,255,255,.08);
border:1px solid rgba(255,255,255,.2);
border-radius:8px;
color:#fff;
font-size:.72rem;
cursor:pointer;
transition:all .2s;
white-space:nowrap;
}
.pw-show-btn:hover{
background:rgba(255,255,255,.15);
}

.admin-note-area{
width:100%;
min-height:100px;
background:rgba(255,255,255,.04);
border:1px solid rgba(255,255,255,.14);
border-radius:12px;
padding:14px 16px;
color:#fff;
font-family:'Raleway',sans-serif;
font-size:.85rem;
outline:none;
resize:vertical;
line-height:1.7;
transition:border .3s;
}
.admin-note-area:focus{
border-color:#fff;
}
.note-saved{
font-size:.72rem;
color:#fff;
display:none;
margin-top:6px;
}

/* EMBED ADMIN CARD */
.embed-input-row{
display:flex;
gap:10px;
align-items:stretch;
}
.embed-input-row input{
flex:1;
margin:0;
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.2);
border-radius:12px;
padding:13px 16px;
color:#fff;
font-family:'Raleway',sans-serif;
font-size:.88rem;
outline:none;
transition:border .3s;
}
.embed-input-row input:focus{
border-color:#fff;
}
.embed-set-btn{
padding:13px 22px;
border:none;
border-radius:12px;
cursor:pointer;
background:linear-gradient(135deg,#fff,#d7d7d7);
color:#000;
font-weight:700;
font-size:.8rem;
transition:all .2s;
box-shadow:0 4px 20px rgba(255,255,255,.14);
white-space:nowrap;
